/* {"URI":"/{id}"} */

#define($_ = $Status<?>(output/status))
#define($_ = $Data<?>(output/view))
#define($_ = $Metrics<?>(output/metrics))
#set($_ = $Page<int>(query/page).QuerySelector(run_rows))

#define($_ = $Id<string>(path/id).WithPredicate(0, 'equal', 't', 'schedule_id'))
#define($_ = $Since<string>(query/since).WithPredicate(1, 'expr', 'created_at >= (SELECT created_at FROM turn WHERE id = ?)'))
#define($_ = $ScheduledFor<time.Time>(query/scheduled_for).WithPredicate(0, 'equal', 't', 'scheduled_for'))
#define($_ = $ExcludeStatuses<[]string>(query/status).WithPredicate(0, 'not_in', 't', 'status'))
#define($_ = $EffectiveUserID<string>(const/value).Value('').WithPredicate(0, 'expr', 'EXISTS (SELECT 1 FROM schedule s WHERE s.id = t.schedule_id AND (s.visibility IS NULL OR s.visibility <> ''private'' OR s.created_by_user_id = ?))'))

SELECT run_rows.*
FROM (
    SELECT t.*
    FROM run t
    ${predicate.Builder().CombineOr($predicate.FilterGroup(0, "AND")).Build("WHERE")}
    ORDER BY started_at DESC, id DESC
) run_rows
